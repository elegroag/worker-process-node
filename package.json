{
  "name": "pm2-task-runner",
  "version": "2.0.0",
  "description": "PM2 service for running scheduled Python and PHP scripts (TypeScript)",
  "main": "dist/src/app.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/src/app.js",
    "start:ts-node": "ts-node --transpile-only src/app.ts",
    "dev": "tsx watch src/app.ts",
    "dev:worker": "tsx watch src/infrastructure/TaskWorker.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "pm2:start": "dotenv -e .env -- pm2 start ecosystem.config.cjs",
    "pm2:start:dev": "dotenv -e .env -- pm2 start ecosystem.config.ts --interpreter tsx",
    "pm2:stop": "pm2 stop task-runner",
    "pm2:restart": "pm2 restart task-runner",
    "pm2:logs": "pm2 logs task-runner",
    "pm2:monit": "pm2 monit",
    "pm2:delete": "pm2 delete task-runner",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "pm2",
    "worker",
    "typescript",
    "tasks"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^17.1.0",
    "moment-timezone": "^0.5.48",
    "mysql2": "^3.14.1",
    "node-cron": "^3.0.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.36.0",
    "pm2": "^5.4.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.45.0"
  }
}